# =============================================================================
# IshTop Frontend — Environment Variables
# =============================================================================
# Copy to frontend/.env.local for local dev. NEVER commit a real .env.
# Only NEXT_PUBLIC_* vars are exposed to the browser — never put secrets here.
# =============================================================================

# Public API base. In production: https://api.ishtop.uz/api/v1
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Public frontend URL used for absolute links and metadata.
NEXT_PUBLIC_FRONTEND_URL=http://localhost:3000

# Web Push (optional). Leave blank to disable push subscription opt-in.
# Generate VAPID key pair: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Optional analytics / monitoring keys (kept public by design)
# NEXT_PUBLIC_SENTRY_DSN=
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
