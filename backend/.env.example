# =============================================================================
# IshTop Backend — Environment Variables
# =============================================================================
# Copy this file to backend/.env and fill in real values for local development.
# NEVER commit a real .env. Production deploys must use a secret manager
# (Railway/Render env vars, Doppler, Vault, etc.).
# Generate SECRET_KEY:  python -c "import secrets; print(secrets.token_hex(32))"
# =============================================================================

# --- Runtime mode ---------------------------------------------------------
# DEBUG: true for local dev (enables /docs, verbose errors). MUST be false in prod.
DEBUG=true

# --- Auth / JWT -----------------------------------------------------------
# SECRET_KEY: REQUIRED. Must be >=32 chars and NOT any default value in prod.
# Backend's _validate_production_secrets raises on weak keys when DEBUG=false.
SECRET_KEY=change-me-use-32-plus-random-bytes-from-secrets-token_hex_32

ALGORITHM=HS256
# Dev default is 30 min. Production validator enforces <=10 min so that the
# unrevoked-token window stays small during a Redis outage (token blacklist
# is fail-open by design; see docs/deployment.md §H).
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Auth cookies (browser session) --------------------------------------
# In production AUTH_COOKIE_SECURE is auto-forced to true by validator.
AUTH_ACCESS_COOKIE_NAME=access_token
AUTH_REFRESH_COOKIE_NAME=refresh_token
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_PATH=/
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_HTTPONLY=true
AUTH_COOKIE_SAMESITE=lax

# --- Rate limiting --------------------------------------------------------
# Disabled in DEBUG by default to avoid local lockouts. MUST be true in prod.
RATE_LIMIT_ENABLED=false
RATE_LIMIT_USE_REDIS=true

# --- Database -------------------------------------------------------------
# Local default: SQLite. Production: Postgres (postgresql://user:pass@host/db).
DATABASE_URL=sqlite:///./ishtop.db

# --- Redis (required in production for JWT blacklist + rate limit) -------
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379/0
TOKEN_BLACKLIST_USE_REDIS=true

# --- CORS — exact origins only (NO wildcards in production) --------------
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Frontend ------------------------------------------------------------
FRONTEND_URL=http://localhost:3000
SUPPORT_EMAIL=support@ishtop.uz

# --- AI provider ---------------------------------------------------------
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4-turbo-preview

# --- OAuth (optional, leave blank to disable) ----------------------------
OAUTH_ENABLED=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/callback/google
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:8000/api/v1/auth/callback/linkedin

# --- Email (SMTP or SendGrid) --------------------------------------------
EMAIL_TRANSPORT=auto
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@ishtop.uz
SMTP_FROM_NAME=IshTop
SMTP_USE_TLS=true
SENDGRID_API_KEY=

# --- Telegram notifications (optional) -----------------------------------
TELEGRAM_BOT_TOKEN=

# --- Admin bootstrap (optional ops helper, blank to disable) -------------
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_FULL_NAME=System Admin

# --- File upload ---------------------------------------------------------
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

# =============================================================================
# PRODUCTION CHECKLIST (set these BEFORE deploying)
# =============================================================================
# DEBUG=false
# SECRET_KEY=<32+ char random>
# AUTH_COOKIE_SECURE=true              (auto-forced)
# RATE_LIMIT_ENABLED=true
# REDIS_ENABLED=true
# REDIS_URL=<production redis>
# DATABASE_URL=postgresql://...        (NOT sqlite)
# CORS_ORIGINS=https://ishtop.uz       (NO wildcards)
# GOOGLE_CLIENT_SECRET=<rotated>       (rotate if ever in local .env)
# =============================================================================
