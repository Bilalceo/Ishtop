# =============================================================================
# Root .env.example — Docker Compose convenience
# =============================================================================
# This file is only used by docker-compose for shared variables when both
# backend and frontend are launched together. NEVER commit real secrets.
# See backend/.env.example and frontend/.env.example for full variable docs.
# =============================================================================

# AI provider for docker-compose backend service
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
